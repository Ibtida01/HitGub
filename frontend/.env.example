# Backend (FastAPI) — used when collaborator REST routes are implemented
VITE_API_URL=http://localhost:8000

# Use mock collaborator data + in-memory notifications (default true)
# Set to false to call the API (requires routes listed in src/services/collabApi.js)
VITE_COLLAB_USE_MOCK=false

# Use mock repository creation/config/branch APIs (default true)
# Set to false to call backend routes listed in docs/repository-api-contract.md
VITE_REPO_USE_MOCK=true
